-- Time is a pair (tick , origin), ordered lexicographically ‚ÄĒ the order
-- induced by the injection (tick , origin) ‚Ü¶ tick * N + origin, i.e. the
-- "timestamps are chosen points of an arithmetic sequence generated by the
-- provenance" scheme, made structural. Two emissions are simultaneous
-- exactly when their Times are equal, and distinct origins can never
-- produce equal Times: the no-accidental-simultaneity invariant holds by
-- construction and survives every operator (a shift only touches the tick).
module Time where

open import Prelude

Time : Set
Time = ‚Ąē √ó ‚Ąē  -- tick , origin

timeEq : Time ‚Üí Time ‚Üí Bool
timeEq (t‚āĀ , o‚āĀ) (t‚āā , o‚āā) = eq‚Ąē t‚āĀ t‚āā ‚ąß eq‚Ąē o‚āĀ o‚āā

timeLt : Time ‚Üí Time ‚Üí Bool
timeLt (t‚āĀ , o‚āĀ) (t‚āā , o‚āā) = lt‚Ąē t‚āĀ t‚āā ‚ą® (eq‚Ąē t‚āĀ t‚āā ‚ąß lt‚Ąē o‚āĀ o‚āā)

timeLeq : Time ‚Üí Time ‚Üí Bool
timeLeq (t‚āĀ , o‚āĀ) (t‚āā , o‚āā) = lt‚Ąē t‚āĀ t‚āā ‚ą® (eq‚Ąē t‚āĀ t‚āā ‚ąß leq‚Ąē o‚āĀ o‚āā)

timeEq-refl : (t : Time) ‚Üí timeEq t t ‚Č° true
timeEq-refl (a , b) rewrite eq‚Ąē-refl a | eq‚Ąē-refl b = refl

timeLeq-refl : (t : Time) ‚Üí timeLeq t t ‚Č° true
timeLeq-refl (a , b) rewrite lt‚Ąē-irrefl a | eq‚Ąē-refl a | leq‚Ąē-refl b = refl

timeLt‚áítimeEq-false : (x y : Time) ‚Üí timeLt x y ‚Č° true ‚Üí timeEq x y ‚Č° false
timeLt‚áítimeEq-false (a , b) (c , d) p with lt‚Ąē a c in lt-ac
... | true rewrite lt‚Ąē‚áíeq‚Ąē-false a c lt-ac = refl
... | false
  rewrite ‚ąß-split-left (eq‚Ąē a c) (lt‚Ąē b d) p
        | lt‚Ąē‚áíeq‚Ąē-false b d (‚ąß-split-right (eq‚Ąē a c) (lt‚Ąē b d) p)
  = refl

timeLt‚áítimeLeq-flip-false :
  (x y : Time) ‚Üí timeLt x y ‚Č° true ‚Üí timeLeq y x ‚Č° false
timeLt‚áítimeLeq-flip-false (a , b) (c , d) p with lt‚Ąē a c in lt-ac
... | true rewrite lt‚Ąē-asym a c lt-ac | lt‚Ąē‚áíeq‚Ąē-false-flip a c lt-ac = refl
... | false
  rewrite eq‚Ąē-sound a c (‚ąß-split-left (eq‚Ąē a c) (lt‚Ąē b d) p)
        | lt‚Ąē-irrefl c
        | eq‚Ąē-refl c
        | lt‚Ąē‚áíleq‚Ąē-flip-false b d (‚ąß-split-right (eq‚Ąē a c) (lt‚Ąē b d) p)
  = refl

-- the beginning of time: a boundary below every Time (closes of not-yet-
-- started observables live here; it is a bound, not an emission, so no
-- origin-ownership is claimed)
timeMin : Time
timeMin = (0 , 0)

timeMin-least : (t : Time) ‚Üí timeLeq timeMin t ‚Č° true
timeMin-least (zero  , b) = refl
timeMin-least (suc a , b) = refl

timeMax : Time ‚Üí Time ‚Üí Time
timeMax x y = if timeLeq x y then y else x

-- helpers that make a timeLeq/timeLt goal compute after rewriting
lt-head-leq : (a c b d : ‚Ąē) ‚Üí lt‚Ąē a c ‚Č° true ‚Üí timeLeq (a , b) (c , d) ‚Č° true
lt-head-leq a c b d p rewrite p = refl

eq-head-leq : (a b d : ‚Ąē) ‚Üí leq‚Ąē b d ‚Č° true ‚Üí timeLeq (a , b) (a , d) ‚Č° true
eq-head-leq a b d p rewrite lt‚Ąē-irrefl a | eq‚Ąē-refl a | p = refl

lt-head-lt : (a c b d : ‚Ąē) ‚Üí lt‚Ąē a c ‚Č° true ‚Üí timeLt (a , b) (c , d) ‚Č° true
lt-head-lt a c b d p rewrite p = refl

eq-head-lt : (a b d : ‚Ąē) ‚Üí lt‚Ąē b d ‚Č° true ‚Üí timeLt (a , b) (a , d) ‚Č° true
eq-head-lt a b d p rewrite lt‚Ąē-irrefl a | eq‚Ąē-refl a | p = refl

timeEq-sound : (x y : Time) ‚Üí timeEq x y ‚Č° true ‚Üí x ‚Č° y
timeEq-sound (a , b) (c , d) p
  with eq‚Ąē-sound a c (‚ąß-split-left (eq‚Ąē a c) (eq‚Ąē b d) p)
     | eq‚Ąē-sound b d (‚ąß-split-right (eq‚Ąē a c) (eq‚Ąē b d) p)
... | refl | refl = refl

timeLt‚áítimeLeq : (x y : Time) ‚Üí timeLt x y ‚Č° true ‚Üí timeLeq x y ‚Č° true
timeLt‚áítimeLeq (a , b) (c , d) p with ‚ą®-split (lt‚Ąē a c) (eq‚Ąē a c ‚ąß lt‚Ąē b d) p
... | left ac = lt-head-leq a c b d ac
... | right r =
  subst (őĽ z ‚Üí timeLeq (a , b) (z , d) ‚Č° true)
        (eq‚Ąē-sound a c (‚ąß-split-left (eq‚Ąē a c) (lt‚Ąē b d) r))
        (eq-head-leq a b d (lt‚Ąē‚áíleq‚Ąē b d (‚ąß-split-right (eq‚Ąē a c) (lt‚Ąē b d) r)))

timeLeq-total : (x y : Time) ‚Üí timeLeq x y ‚Č° false ‚Üí timeLeq y x ‚Č° true
timeLeq-total (a , b) (c , d) h
  with lt‚Ąē-false-split a c (‚ą®-false-left (lt‚Ąē a c) (eq‚Ąē a c ‚ąß leq‚Ąē b d) h)
... | left ca = lt-head-leq c a d b ca
... | right aeqc =
  subst (őĽ z ‚Üí timeLeq (c , d) (z , b) ‚Č° true) (sym aeqc)
        (eq-head-leq c d b
          (leq‚Ąē-false‚áíflip b d
            (‚ąß-true-false (eq‚Ąē a c) (leq‚Ąē b d)
              (eq‚Ąē-complete a c aeqc)
              (‚ą®-false-right (lt‚Ąē a c) (eq‚Ąē a c ‚ąß leq‚Ąē b d) h))))

timeLeq-trans : (x y z : Time)
  ‚Üí timeLeq x y ‚Č° true ‚Üí timeLeq y z ‚Č° true ‚Üí timeLeq x z ‚Č° true
timeLeq-trans (a , b) (c , d) (e , f) p q
  with ‚ą®-split (lt‚Ąē a c) (eq‚Ąē a c ‚ąß leq‚Ąē b d) p
     | ‚ą®-split (lt‚Ąē c e) (eq‚Ąē c e ‚ąß leq‚Ąē d f) q
... | left ac  | left ce  = lt-head-leq a e b f (lt‚Ąē-trans a c e ac ce)
... | left ac  | right r  =
  lt-head-leq a e b f
    (subst (őĽ z‚Ä≤ ‚Üí lt‚Ąē a z‚Ä≤ ‚Č° true)
           (eq‚Ąē-sound c e (‚ąß-split-left (eq‚Ąē c e) (leq‚Ąē d f) r)) ac)
... | right r  | left ce  =
  lt-head-leq a e b f
    (subst (őĽ z‚Ä≤ ‚Üí lt‚Ąē z‚Ä≤ e ‚Č° true)
           (sym (eq‚Ąē-sound a c (‚ąß-split-left (eq‚Ąē a c) (leq‚Ąē b d) r))) ce)
... | right r‚āĀ | right r‚āā =
  subst (őĽ z‚Ä≤ ‚Üí timeLeq (a , b) (z‚Ä≤ , f) ‚Č° true)
        (trans (eq‚Ąē-sound a c (‚ąß-split-left (eq‚Ąē a c) (leq‚Ąē b d) r‚āĀ))
               (eq‚Ąē-sound c e (‚ąß-split-left (eq‚Ąē c e) (leq‚Ąē d f) r‚āā)))
        (eq-head-leq a b f
          (leq‚Ąē-trans b d f
            (‚ąß-split-right (eq‚Ąē a c) (leq‚Ąē b d) r‚āĀ)
            (‚ąß-split-right (eq‚Ąē c e) (leq‚Ąē d f) r‚āā)))

timeLt-trans : (x y z : Time)
  ‚Üí timeLt x y ‚Č° true ‚Üí timeLt y z ‚Č° true ‚Üí timeLt x z ‚Č° true
timeLt-trans (a , b) (c , d) (e , f) p q
  with ‚ą®-split (lt‚Ąē a c) (eq‚Ąē a c ‚ąß lt‚Ąē b d) p
     | ‚ą®-split (lt‚Ąē c e) (eq‚Ąē c e ‚ąß lt‚Ąē d f) q
... | left ac  | left ce  = lt-head-lt a e b f (lt‚Ąē-trans a c e ac ce)
... | left ac  | right r  =
  lt-head-lt a e b f
    (subst (őĽ z‚Ä≤ ‚Üí lt‚Ąē a z‚Ä≤ ‚Č° true)
           (eq‚Ąē-sound c e (‚ąß-split-left (eq‚Ąē c e) (lt‚Ąē d f) r)) ac)
... | right r  | left ce  =
  lt-head-lt a e b f
    (subst (őĽ z‚Ä≤ ‚Üí lt‚Ąē z‚Ä≤ e ‚Č° true)
           (sym (eq‚Ąē-sound a c (‚ąß-split-left (eq‚Ąē a c) (lt‚Ąē b d) r))) ce)
... | right r‚āĀ | right r‚āā =
  subst (őĽ z‚Ä≤ ‚Üí timeLt (a , b) (z‚Ä≤ , f) ‚Č° true)
        (trans (eq‚Ąē-sound a c (‚ąß-split-left (eq‚Ąē a c) (lt‚Ąē b d) r‚āĀ))
               (eq‚Ąē-sound c e (‚ąß-split-left (eq‚Ąē c e) (lt‚Ąē d f) r‚āā)))
        (eq-head-lt a b f
          (lt‚Ąē-trans b d f
            (‚ąß-split-right (eq‚Ąē a c) (lt‚Ąē b d) r‚āĀ)
            (‚ąß-split-right (eq‚Ąē c e) (lt‚Ąē d f) r‚āā)))

timeLt-leq-trans : (x y z : Time)
  ‚Üí timeLt x y ‚Č° true ‚Üí timeLeq y z ‚Č° true ‚Üí timeLt x z ‚Č° true
timeLt-leq-trans (a , b) (c , d) (e , f) p q
  with ‚ą®-split (lt‚Ąē a c) (eq‚Ąē a c ‚ąß lt‚Ąē b d) p
     | ‚ą®-split (lt‚Ąē c e) (eq‚Ąē c e ‚ąß leq‚Ąē d f) q
... | left ac  | left ce  = lt-head-lt a e b f (lt‚Ąē-trans a c e ac ce)
... | left ac  | right r  =
  lt-head-lt a e b f
    (subst (őĽ z‚Ä≤ ‚Üí lt‚Ąē a z‚Ä≤ ‚Č° true)
           (eq‚Ąē-sound c e (‚ąß-split-left (eq‚Ąē c e) (leq‚Ąē d f) r)) ac)
... | right r  | left ce  =
  lt-head-lt a e b f
    (subst (őĽ z‚Ä≤ ‚Üí lt‚Ąē z‚Ä≤ e ‚Č° true)
           (sym (eq‚Ąē-sound a c (‚ąß-split-left (eq‚Ąē a c) (lt‚Ąē b d) r))) ce)
... | right r‚āĀ | right r‚āā =
  subst (őĽ z‚Ä≤ ‚Üí timeLt (a , b) (z‚Ä≤ , f) ‚Č° true)
        (trans (eq‚Ąē-sound a c (‚ąß-split-left (eq‚Ąē a c) (lt‚Ąē b d) r‚āĀ))
               (eq‚Ąē-sound c e (‚ąß-split-left (eq‚Ąē c e) (leq‚Ąē d f) r‚āā)))
        (eq-head-lt a b f
          (lt‚Ąē-leq‚Ąē-trans b d f
            (‚ąß-split-right (eq‚Ąē a c) (lt‚Ąē b d) r‚āĀ)
            (‚ąß-split-right (eq‚Ąē c e) (leq‚Ąē d f) r‚āā)))

timeLeq-false‚áítimeLt-flip : (x y : Time)
  ‚Üí timeLeq x y ‚Č° false ‚Üí timeLt y x ‚Č° true
timeLeq-false‚áítimeLt-flip (a , b) (c , d) h
  with lt‚Ąē-false-split a c (‚ą®-false-left (lt‚Ąē a c) (eq‚Ąē a c ‚ąß leq‚Ąē b d) h)
... | left ca = lt-head-lt c a d b ca
... | right aeqc =
  subst (őĽ z ‚Üí timeLt (c , d) (z , b) ‚Č° true) (sym aeqc)
        (eq-head-lt c d b
          (leq‚Ąē-false‚áílt‚Ąē-flip b d
            (‚ąß-true-false (eq‚Ąē a c) (leq‚Ąē b d)
              (eq‚Ąē-complete a c aeqc)
              (‚ą®-false-right (lt‚Ąē a c) (eq‚Ąē a c ‚ąß leq‚Ąē b d) h))))

timeLeq-neq‚áítimeLt : (x y : Time)
  ‚Üí timeLeq x y ‚Č° true ‚Üí timeEq x y ‚Č° false ‚Üí timeLt x y ‚Č° true
timeLeq-neq‚áítimeLt (a , b) (c , d) p ne
  with ‚ą®-split (lt‚Ąē a c) (eq‚Ąē a c ‚ąß leq‚Ąē b d) p
... | left ac = lt-head-lt a c b d ac
... | right r =
  subst (őĽ z ‚Üí timeLt (a , b) (z , d) ‚Č° true)
        (eq‚Ąē-sound a c (‚ąß-split-left (eq‚Ąē a c) (leq‚Ąē b d) r))
        (eq-head-lt a b d
          (leq‚Ąē-neq‚áílt‚Ąē b d
            (‚ąß-split-right (eq‚Ąē a c) (leq‚Ąē b d) r)
            (‚ąß-true-false (eq‚Ąē a c) (eq‚Ąē b d)
              (‚ąß-split-left (eq‚Ąē a c) (leq‚Ąē b d) r) ne)))

timeLt‚áítimeEq-false-flip : (x y : Time)
  ‚Üí timeLt x y ‚Č° true ‚Üí timeEq y x ‚Č° false
timeLt‚áítimeEq-false-flip (a , b) (c , d) p with lt‚Ąē a c in lt-ac
... | true rewrite lt‚Ąē‚áíeq‚Ąē-false-flip a c lt-ac = refl
... | false
  rewrite eq‚Ąē-sound a c (‚ąß-split-left (eq‚Ąē a c) (lt‚Ąē b d) p)
        | eq‚Ąē-refl c
        | lt‚Ąē‚áíeq‚Ąē-false-flip b d (‚ąß-split-right (eq‚Ąē a c) (lt‚Ąē b d) p)
  = refl

-- distinct origins are never simultaneous, whatever the ticks
neq-origins : (a c o‚āĀ o‚āā : ‚Ąē)
  ‚Üí eq‚Ąē o‚āĀ o‚āā ‚Č° false ‚Üí timeEq (a , o‚āĀ) (c , o‚āā) ‚Č° false
neq-origins a c o‚āĀ o‚āā ne rewrite ne = ‚ąß-absorb-false (eq‚Ąē a c)

timeMax-left : (x y : Time) ‚Üí timeLeq x (timeMax x y) ‚Č° true
timeMax-left x y with timeLeq x y in e
... | true  = e
... | false = timeLeq-refl x

timeMax-right : (x y : Time) ‚Üí timeLeq y (timeMax x y) ‚Č° true
timeMax-right x y with timeLeq x y in e
... | true  = timeLeq-refl y
... | false = timeLeq-total x y e

-- the origin discipline: two emissions at the same tick from distinct
-- origins are never simultaneous
distinct-origins : (t o‚āĀ o‚āā : ‚Ąē)
  ‚Üí eq‚Ąē o‚āĀ o‚āā ‚Č° false ‚Üí timeEq (t , o‚āĀ) (t , o‚āā) ‚Č° false
distinct-origins t o‚āĀ o‚āā ne rewrite ne = ‚ąß-absorb-false (eq‚Ąē t t)

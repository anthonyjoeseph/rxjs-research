{
  "name": "rxjs-instantaneous",
  "version": "0.1.0",
  "private": true,
  "description": "Research: overcoming the RxJS diamond problem with provenance-tracked Instantaneous observables",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "oracle": "jest src/v5/__tests__/oracle.property.test.ts",
    "oracle:burst": "jest src/burst/__tests__/burst-oracle.property.test.ts",
    "oracle:replay": "node scripts/oracle-replay.mjs",
    "oracle:sweep": "node scripts/oracle-sweep.mjs",
    "check": "npm run typecheck && npm test",
    "agda": "cd ../agda && agda src/Everything.agda"
  },
  "dependencies": {
    "pipe-ts": "^0.0.9",
    "rxjs": "^7.8.2",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.8.0",
    "jest": "^29.7.0",
    "prettier": "^3.9.4",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
